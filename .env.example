# ---- Supabase (public — safe to ship to the browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Supabase service role (SERVER ONLY — never prefix with NEXT_PUBLIC_) ----
# Used exclusively by lib/supabase/admin.ts in the invite route.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
# Base URL used for invite redirect links, etc.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
